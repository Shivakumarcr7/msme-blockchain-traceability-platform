generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(MSME_MANAGER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Supplier {
  id                String   @id @default(cuid())
  name              String
  companyName       String
  gstNumber         String   @unique
  contactPerson     String
  email             String
  phone             String
  address           String
  verificationStatus VerificationStatus @default(PENDING)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  products Product[]
  batches  Batch[]
  blockchainRecords BlockchainRecord[]

  @@map("suppliers")
}

